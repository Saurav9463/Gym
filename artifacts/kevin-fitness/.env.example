# ─── Supabase (required) ─────────────────────────────────────────────────────
# Copy these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Replit dev-only (not needed on Vercel) ───────────────────────────────────
# PORT=3000          # dev server port — defaults to 5173 if unset
# BASE_PATH=/        # URL base path — defaults to / if unset
